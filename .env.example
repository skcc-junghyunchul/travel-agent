# Azure OpenAI (LLM)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Tavily (web search for destination trends)
TAVILY_API_KEY=your_tavily_api_key

# Duffel (flights & hotels) — https://app.duffel.com
# Use duffel_test_... token for sandbox, duffel_live_... for production
DUFFEL_API_KEY=duffel_test_your_token_here

# Google Maps (transportation, directions)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Yelp Fusion (restaurants, gyms, parks)
YELP_API_KEY=your_yelp_api_key

# Stripe (payment processing) — use sk_test_... for test mode
STRIPE_API_KEY=sk_test_your_stripe_api_key
